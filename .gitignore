# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/

# Lean / Lake build artifacts
.lake/
lake-packages/
*.olean
*.olean.stamp
*.ilean

# Generated agent nav index (regenerate: scripts/gen_navmap.sh) — kept out of git
# so a stale committed copy can never mislead with wrong line numbers.
.agent/NAVMAP.md

# .serena/ is self-managed by its own nested .serena/.gitignore (/cache,
# /project.local.yml) and committed as is — no repo-root rules. memories/ needs
# none: Serena's memory system is disabled globally (.agent/ is the memory store).

# Project-local elan install (Lean 4 toolchain)
.elan/

# Override a common global-gitignore rule ([Ss]cripts) so the project's
# scripts/ directory is tracked.
!scripts/
!scripts/**
scripts/__pycache__/

# Editor / IDE
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# Secrets
.env
.env.*
!.env.example
