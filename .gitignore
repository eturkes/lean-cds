# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/

# Lean / Lake build artifacts
.lake/
lake-packages/
*.olean
*.olean.stamp
*.ilean

# Generated agent nav index (regenerate: scripts/gen_navmap.sh) — kept out of git
# so a stale committed copy can never mislead with wrong line numbers ([LSN-004]).
.agent/NAVMAP.md

# Headroom's Serena LSP owns .serena/: project.yml + its .gitignore are tracked;
# the cache, machine-local config, and unused memories/ are ignored here at the
# repo root so they survive Serena regenerating its own .gitignore ([DEC-017]).
.serena/cache/
.serena/project.local.yml
.serena/memories/

# Project-local elan install (Lean 4 toolchain)
.elan/

# Override a common global-gitignore rule ([Ss]cripts) so the project's
# scripts/ directory is tracked.
!scripts/
!scripts/**
scripts/__pycache__/

# Editor / IDE
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db

# Secrets
.env
.env.*
!.env.example
